        <mxCell id="L4dQW3Fb067xELG2gg22-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Functional Requirements&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="150" x="25" y="186.25" as="geometry" />
        </mxCell>
        <mxCell id="L4dQW3Fb067xELG2gg22-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;1. User should be able to login to the service.&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;2. User should be able to view content (Pictures/Videos).&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;3. User should be able to get a feed designed as per their preferences.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;4. User should be able to follow other accounts on the platform.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;5. User should be able engage with platform with the feature of likes and comments and message service.&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="475" x="45" y="270" as="geometry" />
        </mxCell>
        <mxCell id="L4dQW3Fb067xELG2gg22-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. User Login Service.&lt;div&gt;2. Content Service&lt;/div&gt;&lt;div&gt;3. Feed Service&lt;/div&gt;&lt;div&gt;4. Follower Service&lt;/div&gt;&lt;div&gt;5. User Engagement Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="340" x="45" y="120" as="geometry" />
        </mxCell>
        <mxCell id="L4dQW3Fb067xELG2gg22-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Non Functional Requirements&lt;/font&gt;" vertex="1">
